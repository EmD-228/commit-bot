# Copier ce fichier en .env et remplir les valeurs.
# Le .env est gitignoré — ne le commit JAMAIS.

# =============================================================================
# COMPTE PRO (source — celui qui commit sur les repos d'entreprise)
# =============================================================================

# Ton username GitHub pro
GITHUB_PRO_USER=ton-username-pro

# Personal Access Token GitHub du compte pro (READ-ONLY)
# Création : https://github.com/settings/tokens (connecté en PRO)
# Scopes :
#   - read:user           (toujours)
#   - repo (read-only)    (si tes commits pro sont dans des repos privés)
GITHUB_PRO_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# COMPTE PERSO (cible — celui qui reçoit les commits miroir)
# =============================================================================

# Ton username GitHub perso
GITHUB_PERSO_USER=ton-username-perso

# Email lié à ton compte perso GitHub (vérifié dans Settings → Emails).
# Sert à `git config user.email` dans le clone cible : garantit l'attribution.
GITHUB_PERSO_EMAIL=ton-email-perso@example.com

# Nom (affichage) — entoure de guillemets si la valeur contient un espace.
GITHUB_PERSO_NAME="Prénom Nom"

# Repo CIBLE qui reçoit les commits miroir.
# C'est le repo où tes commits seront poussés (pas celui où vit ce projet).
# Ex: GITHUB_PERSO_USER si tu veux ton repo de profil, ou un autre repo dédié.
GITHUB_PERSO_REPO=nom-du-repo-cible

# Personal Access Token GitHub du compte perso (REQUIS pour push automatique).
# Création : https://github.com/settings/tokens (connecté en PERSO)
# Scope :
#   - public_repo  (si le repo cible est public)
#   - repo         (si le repo cible est privé)
GITHUB_PERSO_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# CIBLE LOCALE
# =============================================================================

# Dossier local où cloner le repo cible.
# Le bot y travaille (commit, push) sans toucher au projet commit-bot.
# Défaut : ~/.commit-bot-target
# TARGET_CLONE_DIR=$HOME/.commit-bot-target

# Nom du fichier MODIFIÉ dans le repo cible (un commit = une ligne ajoutée).
# Le README du repo cible n'est JAMAIS touché.
# Défaut : notes.md
# TARGET_LOG_FILE=notes.md

# =============================================================================
# RÉGLAGES
# =============================================================================

# Cap quotidien (bot.sh) — au-delà de N contributions pro/jour, on miroir N max.
MAX_COMMITS_PER_DAY=10

# Plancher quotidien (bot.sh) — minimum garanti par jour, même si pro=0.
# Mettre à 0 pour conserver le comportement "miroir strict" (pas de baseline).
MIN_COMMITS_PER_DAY=1

# Cap quotidien des PRs falsifiées (cosmetic.sh).
MAX_PRS_PER_DAY=5

# Jour de la semaine où cosmetic.sh crée 1 issue (1=lundi … 7=dimanche).
ISSUE_WEEKDAY=1

# Timezone IANA (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
# Doit correspondre à celle configurée sur ton profil GitHub.
TZ=Africa/Lome

# =============================================================================
# DISCORD (optionnel — notifications quotidiennes + résumé hebdo)
# =============================================================================

# Webhook URL d'un channel Discord.
# Création : Edit Channel → Integrations → Webhooks → New Webhook → Copy URL.
# Si laissé vide, le bot tourne en silence (aucune notif).
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxxx/yyyyyyyyyy
