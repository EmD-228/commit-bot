# Copier ce fichier en .env et remplir les valeurs.
# Le .env est gitignoré — ne le commit JAMAIS.

# =============================================================================
# COMPTE PRO (source — celui qui commit sur les repos d'entreprise)
# =============================================================================

# Ton username GitHub pro
GITHUB_PRO_USER=ton-username-pro

# Personal Access Token GitHub du compte pro (READ-ONLY)
# Création : https://github.com/settings/tokens (connecté en PRO)
# Scopes minimums :
#   - read:user           (toujours)
#   - repo (read-only)    (uniquement si tes commits pro sont dans des repos privés)
# Recommandation : token "fine-grained" avec expiration courte (90j).
GITHUB_PRO_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# COMPTE PERSO (cible — celui qui reçoit les commits miroir)
# =============================================================================

# Ton username GitHub perso
GITHUB_PERSO_USER=ton-username-perso

# Email lié à ton compte perso GitHub
# Vérifié dans https://github.com/settings/emails (connecté en PERSO)
# Sert à `git config user.email` local pour que les commits comptent sur ton graphe.
GITHUB_PERSO_EMAIL=ton-email-perso@example.com

# Nom (affichage) lié à ton compte perso — optionnel, défaut = git config user.name actuel
# IMPORTANT : si la valeur contient un espace, il FAUT mettre des guillemets.
GITHUB_PERSO_NAME="Prénom Nom"

# Nom du repo perso qui reçoit les commits miroir
GITHUB_PERSO_REPO=commit-bot

# Personal Access Token GitHub du compte perso (recommandé pour cron)
# Création : https://github.com/settings/tokens (connecté en PERSO)
# Scopes minimums :
#   - repo                (write sur ton repo perso)
# Si laissé vide, le script tentera de pusher via le remote `origin` existant
# (dépend alors du keychain macOS / SSH config).
GITHUB_PERSO_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# RÉGLAGES
# =============================================================================

# Cap quotidien — au-delà de N commits pro dans une journée, on miroir N max.
# Empêche un graphe absurde si tu fais 50 commits dans une journée intense.
# Valeur recommandée : 5 à 10 pour rester crédible.
MAX_COMMITS_PER_DAY=10

# Timezone à utiliser pour définir "aujourd'hui" lors de la requête API.
# Format IANA (voir https://en.wikipedia.org/wiki/List_of_tz_database_time_zones).
# Exemples : America/New_York, America/Toronto, Europe/Paris, Africa/Lome
# Doit correspondre à la TZ configurée sur ton profil GitHub
# (https://github.com/settings — section "Timezone" du graphe de contributions).
TZ=America/New_York
